# ─── 自前アナリティクス（Neon Postgres・Cookie不使用/IP非保存）───
# Neon の接続文字列（Vercel の Neon 連携で自動注入される場合あり）
DATABASE_URL=''
# 訪問者ハッシュ用のソルト（本番では必ず固有のランダム文字列を設定）
ANALYTICS_SALT_SECRET=''
# Cron（/api/cron/analytics-rollup）保護用の共通シークレット
CRON_SECRET=''

# 管理ダッシュボード（/admin/analytics）初期パスワード設定用。
# setup-admin-auth.mjs 実行時のみ使用（DBに保存後は不要）
ADMIN_PASSWORD=''
ADMIN_RECOVERY_EMAIL=''
ADMIN_SECURITY_QUESTION=''
ADMIN_SECURITY_ANSWER=''

# ─── Google Analytics 4（任意）───
# 設定すると GA4 にもイベントを送信する（未設定なら自前計測のみ）
NEXT_PUBLIC_GA_ID=''
